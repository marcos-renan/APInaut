{
  "name": "apinaut",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "next dev --port 3210",
    "dev:electron": "wait-on tcp:3210 && cross-env ELECTRON_START_URL=http://localhost:3210 electron electron/main.mjs",
    "build": "next build",
    "start": "next start --port 3210",
    "start:electron": "concurrently -k \"npm:start\" \"npm:start:desktop\"",
    "start:desktop": "wait-on tcp:3210 && cross-env ELECTRON_START_URL=http://localhost:3210 electron electron/main.mjs",
    "lint": "eslint"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@radix-ui/react-slot": "^1.2.4",
    "@uiw/react-codemirror": "^4.25.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
